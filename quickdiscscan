#!/usr/bin/env bash

set -euo pipefail

project_dir=$(cd -- "$(dirname -- "$0")" && pwd -P)
case $(uname -s) in
    Darwin) app=$project_dir/dist/QuickDiscScan.app/Contents/MacOS/QuickDiscScan ;;
    Linux) app=$project_dir/dist/QuickDiscScan/bin/QuickDiscScan ;;
    *) printf 'Unter Windows bitte dist\\QuickDiscScan\\QuickDiscScan.exe starten.\n' >&2; exit 1 ;;
esac

if [[ ! -x $app ]]; then
    "$project_dir/build.sh"
fi

exec "$app" "$@"
